global:
    scrape_interval: 15s
    scrape_timeout: 10s
    evaluation_interval: 15s
rule_files:
    - /opt/prometheus/rules/*.yml
scrape_configs:
    # SNMP polling of the peering switches via snmp_exporter. Targets are
    # enumerated from NetBox by the netbox-prometheus-sd timer (file_sd).
    # some switches (e.g. switch03/04.sjc01) rate-limit SNMP and take ~45s
    # for a walk that others answer in 5s — hence the split into two jobs
    # (interfaces vs health) with generous timeouts, so neither walk alone
    # busts the scrape deadline.
    - job_name: snmp-eos
      scrape_interval: 60s
      scrape_timeout: 55s
      metrics_path: /snmp
      params:
          module: [if_mib]
          auth: [sfmix_v2c]
      file_sd_configs:
          - files:
              - /opt/prometheus/file_sd/snmp_targets.json
      relabel_configs:
          - source_labels: [__address__]
            target_label: __param_target
          - source_labels: [__param_target]
            target_label: host          # matches the sflow series' FQDN label
          - source_labels: [__param_target]
            target_label: instance
          - target_label: __address__
            replacement: 127.0.0.1:9116
      metric_relabel_configs:
          - source_labels: [ifName]     # match the sflow/portal join key
            target_label: ifname
          - regex: ifName
            action: labeldrop
    - job_name: snmp-eos-health
      scrape_interval: 120s
      scrape_timeout: 110s
      metrics_path: /snmp
      params:
          module: [eos_health]
          auth: [sfmix_v2c]
      file_sd_configs:
          - files:
              - /opt/prometheus/file_sd/snmp_targets.json
      relabel_configs:
          - source_labels: [__address__]
            target_label: __param_target
          - source_labels: [__param_target]
            target_label: host
          - source_labels: [__param_target]
            target_label: instance
          - target_label: __address__
            replacement: 127.0.0.1:9116
    # SNMP polling of the PDUs (mixed vendors) via snmp_exporter. Targets come
    # from the netbox-prometheus-sd-pdu timer, which stamps each with the right
    # snmp_exporter `module` (ServerTech Sentry3 vs Raritan PDU2) from the
    # NetBox manufacturer. One job serves the whole fleet: the per-target
    # `module` label is relabeled to __param_module. `vendor`/`site`/`device`
    # ride along as series labels; the pdu:* recording rules normalise the two
    # vendors' native metrics into common base-SI series.
    - job_name: snmp-pdu
      scrape_interval: 60s
      scrape_timeout: 55s
      metrics_path: /snmp
      params:
          auth: [sfmix_v2c]
      file_sd_configs:
          - files:
              - /opt/prometheus/file_sd/pdu_targets.json
      relabel_configs:
          - source_labels: [__address__]
            target_label: __param_target
          - source_labels: [__param_target]
            target_label: instance
          - source_labels: [module]     # vendor-aware: NetBox manufacturer -> module
            target_label: __param_module
          - target_label: __address__
            replacement: 127.0.0.1:9116
    # Portal metrics: NetBox-cache health + sfmix_peering_port_info (the
    # participant/ASN attribution joined onto SNMP series by recording rules).
    - job_name: ixp-portal
      scheme: https
      metrics_path: /metrics/
      scrape_interval: 60s
      static_configs:
      - targets:
          - portal.sfmix.org
    - job_name: sflow-rt-ifcounters
      metrics_path: /prometheus/metrics/ALL/ifinoctets,ifoutoctets,ifinutilization,ifoututilization,ifinerrors,ifouterrors,ifindiscards,ifoutdiscards/txt
      scheme: http
      scrape_interval: 5s
      scrape_timeout: 4s
      static_configs:
      - targets:
          - metrics.sfo02.sfmix.org:8008
      metric_relabel_configs:
          - source_labels: ['agent', 'datasource']
            separator: ':'
            target_label: instance
    - job_name: sflow-rt-ixp-metrics
      metrics_path: /app/ixp-metrics/scripts/metrics.js/prometheus/txt
      scheme: http
      scrape_interval: 5s
      scrape_timeout: 4s
      static_configs:
      - targets:
          - metrics.sfo02.sfmix.org:8008
    - job_name: sflow-rt-pre-amp
      metrics_path: /app/prometheus/scripts/export.js/flows/ALL/txt
      scheme: http
      scrape_interval: 10s
      scrape_timeout: 4s
      static_configs:
        - targets:
          - metrics.sfo02.sfmix.org:8008
      params:
        metric: ["pre_amp_suspect_frames"]
        key: ["udpsourceport", "udpdestinationport"]
        label: ["udp_source_port", "udp_destination_port"]
        value: ["frames"]
        aggMode: ["edge"]
        filter: ["udpsourceport=80,443&udpdestinationport=17,19,53,111,123,161,389,520,1900,11211"]
        # This should at least be sized at the product of the source and destination ports
        maxFlows: ["100"]
    - job_name: sflow-rt-drops
      metrics_path: /app/prometheus/scripts/export.js/flows/ALL/txt
      scheme: http
      scrape_interval: 10s
      scrape_timeout: 4s
      static_configs:
        - targets:
          - metrics.sfo02.sfmix.org:8008
      params:
        metric: ["dropped_packets"]
        key: ["node:inputifindex","ifname:inputifindex","reason","stack","macsource","macdestination","null:vlan:untagged","null:[or:ipsource:ip6source]:none","null:[or:ipdestination:ip6destination]:none","null:[or:icmptype:icmp6type:ipprotocol:ip6nexthdr]:none"]
        label: ["switch","port","reason","stack","macsource","macdestination","vlan","src","dst","protocol"]
        value: ["frames"]
        dropped: ["true"]
        maxFlows: ["20"]
        minValue: ["0.001"]
    - job_name: sflow-rt-as40271
      metrics_path: /app/prometheus/scripts/export.js/flows/ALL/txt
      scheme: http
      scrape_interval: 10s
      scrape_timeout: 4s
      static_configs:
        - targets:
          - metrics.sfo02.sfmix.org:8008
      params:
        metric: ["as40271"]
        key: ["asn:[or:ipsource:ip6source]:both","asn:[or:ipdestination:ip6destination]:both","uc:[first:stack:.:ip:ip6]"]
        label: ["source", "destination","protocol"]
        value: ["bytes"]
        scale: ["8"]
        aggMode: ["edge"]
        filter: ["(macsource=9C47F46D4231,9C47F46D2631|macdestination=9C47F46D4231,9C47F46D2631)&first:stack:.:mpls=null"]
        maxFlows: ["100"]
    - job_name: netbox
      scheme: https
      scrape_interval: 10s
      scrape_timeout: 5s
      static_configs:
      - targets:
        - netbox.sfmix.org
    - job_name: mqtt2prometheus-air-sensor
      scheme: http
      scrape_interval: 5s
      scrape_timeout: 4s
      static_configs:
      - targets:
        - metrics.sfo02.sfmix.org:9641
      metric_relabel_configs:
        - source_labels: [sensor]
          regex: '(sfo01|sfo02|scl05)'
          target_label: facility_operator
          replacement: digital_realty
        - source_labels: [sensor]
          regex: '(fmt01)'
          target_label: facility_operator
          replacement: hurricane_electric
        - source_labels: [sensor]
          regex: '(scl01)'
          target_label: facility_operator
          replacement: qts
        - source_labels: [sensor]
          regex: '(scl02|sjc02)'
          target_label: facility_operator
          replacement: coresite
        - source_labels: [sensor]
          regex: '(sjc01)'
          target_label: facility_operator
          replacement: equinix
        - source_labels: [sensor]
          regex: '(scl04)'
          target_label: facility_operator
          replacement: opencolo
    - job_name: bird_exporer
      scheme: http
      scrape_interval: 60s
      scrape_timeout: 15s
      static_configs:
        - targets:
            - 10.1.1.18:9324
