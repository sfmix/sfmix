server {
    listen 80;
    listen [::]:80;
    server_name {{ akvorado_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ akvorado_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ akvorado_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ akvorado_domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ akvorado_domain }}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
{% if akvorado_basic_auth_password != "" %}
        auth_basic "Akvorado";
        auth_basic_user_file /etc/nginx/htpasswd-akvorado;

{% endif %}
        proxy_pass http://127.0.0.1:{{ akvorado_http_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
