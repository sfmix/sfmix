---
clients:
{% for participant_id, participant in netbox_participants.items() %}
{%   if participant.custom_fields.as_number != arouteserver_rs_asn %}
{%     if participant.custom_fields.as_number == 12276 %}
  - asn: 12276
    description: SFMIX
    cfg:
      attach_custom_communities:
        - "participant_type_infrastructure"
        - "colo_sfo02"
      filtering:
        rpki:
          reject_invalid: True
        max_prefix:
          peering_db:
            enabled: True
    ip:
      - "206.197.187.2"
      - "2001:504:30::ba01:2276:2"
  - asn: 12276
    description: SFMIX
    cfg:
      attach_custom_communities:
        - "participant_type_infrastructure"
        - "colo_fmt01"
      filtering:
        rpki:
          reject_invalid: True
        max_prefix:
          peering_db:
            enabled: True
    ip:
      - "206.197.187.3"
      - "2001:504:30::ba01:2276:3"
{%     else %}
{%       for peering_port_id, peering_port in netbox_peering_port_interfaces.items() %}
{%         if peering_port.custom_fields.participant and peering_port.custom_fields.participant.id == participant_id %}
{%           set port_ips = netbox_participant_ip_addresses.values()
                 | selectattr('custom_fields.participant_lag')
                 | selectattr('custom_fields.participant_lag.id', 'equalto', peering_port.id)
                 | map(attribute='address')
                 | map('ansible.utils.ipaddr', 'address')
                 | list %}
{%           if not port_ips %}
  # AS{{ participant.custom_fields.as_number }} port {{ netbox_devices[peering_port.device.id].name }} {{ peering_port.name }} skipped: no participant IPs in NetBox
{%           else %}
  - asn: {{ participant.custom_fields.as_number }}
    description: {{ participant.description }}
    ip:
{%           for ip_address in port_ips %}
      - "{{ ip_address }}"
{%           endfor %}
    cfg:
      attach_custom_communities:
        - "participant_type_{{ participant.custom_fields.participant_type | lower }}"
        - "colo_{{ netbox_sites[netbox_devices[peering_port.device.id].site.id].name }}"
      filtering:
        rpki:
          reject_invalid: True
        max_prefix:
          peering_db:
            enabled: True
{%           endif %}
{%         endif %}
{%       endfor %}
{%     endif %}
{%   endif %}
{% endfor %}
