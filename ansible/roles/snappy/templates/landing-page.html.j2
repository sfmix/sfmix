<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Test your network speed to the San Francisco Metropolitan Internet eXchange (SFMIX). LibreSpeed, OpenSpeedTest, iperf3, and TR-143 endpoints available.">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="SFMIX Snappy Speed Test">
    <meta property="og:description" content="Test your network speed to the San Francisco Metropolitan Internet eXchange. Multiple speed test tools available.">
    <meta property="og:url" content="https://{{ snappy_speedtest_domain }}/">
    <meta property="og:site_name" content="SFMIX">
    <meta property="og:image" content="https://{{ snappy_speedtest_domain }}/static/sfmix-fiber-spray.png">
    <meta property="og:image:width" content="1024">
    <meta property="og:image:height" content="512">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="SFMIX Snappy Speed Test">
    <meta name="twitter:description" content="Test your network speed to the San Francisco Metropolitan Internet eXchange. Multiple speed test tools available.">
    <meta name="twitter:image" content="https://{{ snappy_speedtest_domain }}/static/sfmix-fiber-spray.png">

    <title>SFMIX Snappy - Speed Test</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            min-height: 100vh;
            background: #0d1117;
            color: #e0e0e0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Animated rainbow top bar */
        .rainbow-bar {
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg,
                #ff0000, #ff7700, #ffdd00, #00cc44, #0088ff, #8800ff, #ff0000);
            background-size: 200% 100%;
            animation: slide 3s linear infinite;
        }
        @keyframes slide { to { background-position: 200% 0; } }

        /* Hero banner with CSS fiber strands */
        .hero {
            width: 100%;
            height: 180px;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, #0d1117 0%, #111827 100%);
        }

        .fiber {
            position: absolute;
            height: 3px;
            border-radius: 3px;
            filter: blur(1px);
            opacity: 0;
            animation: shoot 3s ease-in-out infinite;
        }
        .fiber::after {
            content: '';
            position: absolute;
            right: 0;
            top: -3px;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: inherit;
            filter: blur(3px);
        }

        .fiber:nth-child(1)  { top: 15%;  background: #ff4444; width: 0; left: -5%;  animation-delay: 0.0s; animation-duration: 2.8s; }
        .fiber:nth-child(2)  { top: 25%;  background: #ff8800; width: 0; left: -8%;  animation-delay: 0.3s; animation-duration: 3.2s; }
        .fiber:nth-child(3)  { top: 40%;  background: #ffdd00; width: 0; left: -3%;  animation-delay: 0.7s; animation-duration: 2.5s; }
        .fiber:nth-child(4)  { top: 55%;  background: #00cc44; width: 0; left: -10%; animation-delay: 0.1s; animation-duration: 3.0s; }
        .fiber:nth-child(5)  { top: 65%;  background: #0088ff; width: 0; left: -6%;  animation-delay: 0.5s; animation-duration: 2.7s; }
        .fiber:nth-child(6)  { top: 78%;  background: #8844ff; width: 0; left: -2%;  animation-delay: 0.9s; animation-duration: 3.4s; }
        .fiber:nth-child(7)  { top: 88%;  background: #ff44aa; width: 0; left: -7%;  animation-delay: 0.4s; animation-duration: 2.6s; }
        .fiber:nth-child(8)  { top: 32%;  background: #44ddff; width: 0; left: -4%;  animation-delay: 1.1s; animation-duration: 3.1s; }
        .fiber:nth-child(9)  { top: 48%;  background: #ff6644; width: 0; left: -9%;  animation-delay: 0.6s; animation-duration: 2.9s; }
        .fiber:nth-child(10) { top: 72%;  background: #88ff44; width: 0; left: -1%;  animation-delay: 1.3s; animation-duration: 3.3s; }

        @keyframes shoot {
            0%   { width: 0;    opacity: 0; }
            10%  { opacity: 0.9; }
            50%  { width: 110%; opacity: 0.7; }
            80%  { opacity: 0.3; }
            100% { width: 110%; opacity: 0; }
        }

        /* SF skyline silhouette at bottom of hero */
        .skyline {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 60px;
        }
        .skyline svg { width: 100%; height: 100%; }

        .container {
            max-width: 720px;
            width: 100%;
            padding: 40px 24px;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        h1 {
            font-size: 2.4em;
            font-weight: 700;
            background: linear-gradient(90deg, #ff6b6b, #ffa94d, #ffd43b, #69db7c, #4dabf7, #b197fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 1.05em;
            color: #6b7b8d;
            letter-spacing: 0.5px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 40px;
        }

        .card {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 28px 24px;
            text-decoration: none;
            color: #e0e0e0;
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            border-radius: 16px 16px 0 0;
            opacity: 0.8;
        }

        .card-librespeed::before { background: linear-gradient(90deg, #ff6b6b, #ffa94d); }
        .card-openspeedtest::before { background: linear-gradient(90deg, #4dabf7, #69db7c); }

        .card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
        }

        .card .icon { font-size: 2em; margin-bottom: 12px; }
        .card h2 { font-size: 1.15em; margin-bottom: 6px; color: #fff; }
        .card p { font-size: 0.85em; color: #6b7b8d; line-height: 1.5; }

        .cli-section {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 40px;
        }

        .cli-section h2 {
            font-size: 0.8em;
            color: #6b7b8d;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
        }

        .cli-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
        }

        .cli-item + .cli-item {
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .cli-item .label {
            font-weight: 600;
            color: #b197fc;
            min-width: 72px;
            font-size: 0.9em;
        }

        .cli-item code {
            background: rgba(0, 0, 0, 0.4);
            padding: 5px 10px;
            border-radius: 6px;
            font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
            font-size: 0.82em;
            color: #69db7c;
            word-break: break-all;
        }

        footer {
            text-align: center;
            color: #3d4550;
            font-size: 0.82em;
            padding-bottom: 32px;
        }

        footer a { color: #4dabf7; text-decoration: none; }
        footer a:hover { text-decoration: underline; }

        @media (max-width: 600px) {
            .card-grid { grid-template-columns: 1fr; }
            h1 { font-size: 1.6em; }
            .hero { height: 120px; }
            .cli-item { flex-direction: column; align-items: flex-start; gap: 4px; }
        }
    </style>
</head>
<body>
    <div class="rainbow-bar"></div>
    <div class="hero">
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="fiber"></div>
        <div class="skyline">
            <svg viewBox="0 0 1200 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Continuous base: western hills, Twin Peaks, Nob Hill, all FiDi/SoMa buildings, eastern waterfront — no gaps -->
                <path d="M0,60 L0,52 30,50 60,48 90,46 110,47 130,46 160,47 180,46 200,47
                    210,46 220,42 235,38 245,40 255,36 270,40 285,42 300,44 310,46
                    320,44 335,42 345,43 355,42 365,43 375,42 385,44
                    385,44 390,44 390,42 394,42 394,44
                    400,44 400,42 410,42 410,40 420,40 420,38 432,38 432,40 440,40 440,42
                    442,42 442,36 458,36 458,42
                    460,42 460,30 476,30 476,42
                    478,42 478,34 490,34 490,42
                    492,42 492,28 504,28 504,42
                    506,42 506,18 528,18 528,42
                    530,42 530,28 544,28 544,42
                    546,42 546,12 548,8 550,5 553,3 556,5 558,8 560,12 560,42
                    562,42 562,20 576,20 576,42
                    578,42 578,26 588,26 588,42
                    590,42 590,32 602,32 602,42
                    604,42 604,38 616,38 616,42
                    618,42 618,40 632,40 632,42
                    634,42 634,44 660,44 660,46
                    670,46 700,47 740,48 790,48 830,50 880,52 950,54 1050,56 1200,58 1200,60 Z"
                    fill="#2a3648"/>
                <!-- Sutro Tower: two tapered lattice legs -->
                <path d="M188,46 L191,46 195,24 194,24 190,46 Z" fill="#4a2a2a"/>
                <path d="M203,46 L206,46 202,24 201,24 205,46 Z" fill="#4a2a2a"/>
                <!-- Sutro Tower: cross-braces between legs -->
                <line x1="192" y1="38" x2="203" y2="38" stroke="#4a2a2a" stroke-width="1"/>
                <line x1="193" y1="32" x2="202" y2="32" stroke="#4a2a2a" stroke-width="1"/>
                <line x1="194" y1="26" x2="201" y2="26" stroke="#4a2a2a" stroke-width="1"/>
                <!-- Sutro Tower: horizontal platform at top of legs -->
                <rect x="193" y="23" width="10" height="2" fill="#4a2a2a"/>
                <!-- Sutro Tower: center mast -->
                <rect x="197" y="6" width="2" height="17" fill="#4a2a2a"/>
                <!-- Sutro Tower: left antenna prong -->
                <path d="M194,23 L192,10 193,10 195,23 Z" fill="#4a2a2a"/>
                <!-- Sutro Tower: right antenna prong -->
                <path d="M201,23 L203,10 204,10 202,23 Z" fill="#4a2a2a"/>
                <!-- Sutro Tower: antenna tips -->
                <line x1="192" y1="10" x2="192" y2="6" stroke="#4a2a2a" stroke-width="1"/>
                <line x1="198" y1="6" x2="198" y2="2" stroke="#4a2a2a" stroke-width="1"/>
                <line x1="204" y1="10" x2="204" y2="6" stroke="#4a2a2a" stroke-width="1"/>
                <!-- Coit Tower: tapered column with observation cap -->
                <path d="M392,44 L393,42 394,26 394,24 393,23 393,22 403,22 403,23 402,24 402,26 403,42 404,44 Z" fill="#2a3648"/>
                <!-- Transamerica Pyramid: tall solid triangle -->
                <polygon points="490,2 480,60 500,60" fill="#2a3648"/>
                <!-- Transamerica Pyramid: inverted triangle for observation wings (flat top = wings, apex down) -->
                <polygon points="484,12 496,12 490,18" fill="#2a3648"/>
                <!-- Bay Bridge west tower: two vertical columns with cross-beam -->
                <rect x="670" y="14" width="3" height="34" fill="#4a2a2a"/>
                <rect x="677" y="14" width="3" height="34" fill="#4a2a2a"/>
                <rect x="670" y="14" width="10" height="2" fill="#4a2a2a"/>
                <rect x="670" y="28" width="10" height="2" fill="#4a2a2a"/>
                <!-- Bay Bridge suspension cables -->
                <path d="M640,46 Q660,30 675,14" stroke="#4a2a2a" stroke-width="0.7" fill="none"/>
                <path d="M710,46 Q690,30 675,14" stroke="#4a2a2a" stroke-width="0.7" fill="none"/>
                <!-- Rolling fog: organic shapes with drift animations -->
                <defs>
                    <filter id="fogBlur">
                        <feGaussianBlur stdDeviation="4 2"/>
                    </filter>
                </defs>
                <g filter="url(#fogBlur)">
                    <!-- Low fog bank: thick rolling layer -->
                    <path d="M-100,48 C50,42 120,46 200,40 C280,36 350,44 450,38 C550,34 620,42 750,38 C880,34 1000,42 1100,40 L1300,44 L1300,60 L-100,60 Z"
                        fill="white" opacity="0.08">
                        <animateTransform attributeName="transform" type="translate" values="0,0;60,2;-40,-1;0,0" dur="8s" repeatCount="indefinite"/>
                    </path>
                    <!-- Mid fog wisps -->
                    <path d="M-50,38 C80,34 160,40 280,34 C400,28 460,36 560,32 C660,28 740,34 860,30 C980,26 1080,34 1250,32 L1300,36 L1300,46 L-50,46 Z"
                        fill="white" opacity="0.06">
                        <animateTransform attributeName="transform" type="translate" values="0,0;-50,1;30,-1;0,0" dur="12s" repeatCount="indefinite"/>
                    </path>
                    <!-- High fog wisps: thin tendrils around tower tops -->
                    <path d="M200,24 C300,20 380,26 480,22 C580,18 640,24 720,20 C800,16 860,22 950,20 L950,30 C860,32 800,26 720,30 C640,34 580,28 480,32 C380,36 300,30 200,34 Z"
                        fill="white" opacity="0.05">
                        <animateTransform attributeName="transform" type="translate" values="0,0;40,-2;-60,1;0,0" dur="15s" repeatCount="indefinite"/>
                    </path>
                    <!-- Extra wisp: small drifting patch -->
                    <path d="M400,28 C440,24 500,30 560,26 C620,22 660,28 700,24 L700,34 C660,38 620,32 560,36 C500,40 440,34 400,38 Z"
                        fill="white" opacity="0.07">
                        <animateTransform attributeName="transform" type="translate" values="0,0;-35,2;50,-1;0,0" dur="6s" repeatCount="indefinite"/>
                    </path>
                </g>
            </svg>
        </div>
    </div>
    <div class="container">
        <header>
            <h1>Snappy Speed Test</h1>
            <p class="subtitle">San Francisco Metropolitan Internet eXchange</p>
        </header>

        <div class="card-grid">
            <a href="/librespeed/" class="card card-librespeed">
                <div class="icon">&#9889;</div>
                <h2>LibreSpeed</h2>
                <p>Rust-powered speed test with ping, jitter, download &amp; upload measurements.</p>
            </a>
            <a href="/openspeedtest/" class="card card-openspeedtest">
                <div class="icon">&#127760;</div>
                <h2>OpenSpeedTest</h2>
                <p>HTML5-based network performance test. No Flash, no Java, no plugins.</p>
            </a>
        </div>

        <div class="cli-section">
            <h2>CLI &amp; TR-143 Endpoints</h2>
            <div class="cli-item">
                <span class="label"><a href="https://github.com/esnet/iperf" style="color: #b197fc; text-decoration: none;">iperf3</a></span>
                <div>
                    <code>iperf3 -c {{ snappy_speedtest_domain }}</code>
                    <div style="font-size: 0.78em; color: #6b7b8d; margin-top: 4px;">The standard network throughput measurement tool. Single-client TCP/UDP testing.</div>
                </div>
            </div>
            <div class="cli-item">
                <span class="label"><a href="https://github.com/lance0/xfr" style="color: #b197fc; text-decoration: none;">xfr</a></span>
                <div>
                    <code>xfr {{ snappy_speedtest_domain }} -p {{ xfr_port }}</code>
                    <div style="font-size: 0.78em; color: #6b7b8d; margin-top: 4px;">Modern iperf3 alternative with multi-client server, QUIC support, and live TUI. Built in Rust.</div>
                </div>
            </div>
            <div class="cli-item">
                <span class="label">TAUC DL</span>
                <code>https://{{ snappy_speedtest_domain }}/tauc/downloads/20MB.file</code>
            </div>
        </div>

        <footer>
            Operated by <a href="https://sfmix.org">SFMIX</a> &mdash; AS40271
        </footer>
    </div>
</body>
</html>
