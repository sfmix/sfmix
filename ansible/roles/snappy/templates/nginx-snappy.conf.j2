server {
    listen 80;
    listen [::]:80;
    server_name {{ snappy_speedtest_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ snappy_speedtest_domain }};

    # Certs managed by certbot
    ssl_certificate /etc/letsencrypt/live/{{ snappy_speedtest_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ snappy_speedtest_domain }}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/{{ snappy_speedtest_domain }}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    client_max_body_size 100M;

    # Root landing page
    location = / {
        return 200 '<!DOCTYPE html>
<html>
<head>
    <title>SFMIX Speed Test</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 800px; margin: 50px auto; padding: 20px; }
        h1 { color: #333; }
        .speedtest-links { list-style: none; padding: 0; }
        .speedtest-links li { margin: 15px 0; }
        .speedtest-links a { display: block; padding: 15px; background: #007bff; color: white; text-decoration: none; border-radius: 5px; }
        .speedtest-links a:hover { background: #0056b3; }
    </style>
</head>
<body>
    <h1>SFMIX Speed Test Services</h1>
    <p>Choose a speed test service:</p>
    <ul class="speedtest-links">
        <li><a href="/librespeed/">LibreSpeed (Rust-based)</a></li>
        <li><a href="/openspeedtest/">OpenSpeedTest</a></li>
    </ul>
    <h2>TR-143 / CLI Endpoints</h2>
    <ul>
        <li>TAUC download: <code>https://snappy.sfmix.org/tauc/downloads/20MB.file</code></li>
        <li>iperf3: <code>iperf3 -c snappy.sfmix.org</code></li>
    </ul>
</body>
</html>';
        add_header Content-Type text/html;
    }

    # LibreSpeed
    location /librespeed/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # TAUC Speed Test
    location /tauc/ {
        proxy_pass http://127.0.0.1:8081/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # OpenSpeedTest
    location /openspeedtest/ {
        proxy_pass http://127.0.0.1:8082/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
