{% set cert_path = "/etc/letsencrypt/live/" + ixp_portal_domain %}
{% set has_cert = _portal_cert.stat.exists | default(false) %}

# HTTP — redirect to HTTPS (or serve ACME challenge if no cert yet)
server {
    listen 80;
    listen [::]:80;
    server_name {{ ixp_portal_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

{% if has_cert %}
    location / {
        return 301 https://{{ ixp_portal_domain }}$request_uri;
    }
{% endif %}
}

{% if has_cert %}
# HTTPS — reverse proxy to portal container
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ ixp_portal_domain }};

    ssl_certificate {{ cert_path }}/fullchain.pem;
    ssl_certificate_key {{ cert_path }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Ubuntu's stock nginx gzips only text/html: the network-map's map.json and
    # the Django-proxied /statistics/map/traffic feed otherwise go over the wire
    # uncompressed. gzip_proxied covers the proxy_pass responses below.
    gzip on;
    gzip_types application/json application/javascript text/css image/svg+xml;
    gzip_min_length 1024;
    gzip_comp_level 5;
    gzip_vary on;
    gzip_proxied any;

    # Built + static assets are served straight from disk (bind mounts the portal
    # container writes to), never streamed through Django/gunicorn:
    #   /static/                    -> collectstatic output
    #   /statistics/map/map.json    -> PUBLIC network-map structure (CORS-open)
    #   /statistics/map/weathermap.json -> PUBLIC schematic weathermap (CORS-open)
    #   /statistics/map/logos/      -> cached operator logos (was hotlinked from
    #                                  peeringdb.com; now downloaded at build time)
    # The PRIVATE map-links.json lives on the db named volume, outside these dirs,
    # so it is not reachable here. The dynamic /statistics/map/traffic feed and
    # everything else fall through to Django below.
    # Host paths must match the bind mounts in portal/docker-compose.yml.
    location /static/ {
        alias {{ ixp_portal_static_dir | default('/opt/sfmix/portal-static') }}/;
        access_log off;
        expires 30d;
        add_header Cache-Control "public";
    }

    location = /statistics/map/map.json {
        alias {{ ixp_portal_map_public_dir | default('/opt/sfmix/map-public') }}/map.json;
        default_type application/json;
        add_header Access-Control-Allow-Origin "*";
        add_header Cache-Control "public, max-age=300";
    }

    location = /statistics/map/weathermap.json {
        alias {{ ixp_portal_map_public_dir | default('/opt/sfmix/map-public') }}/weathermap.json;
        default_type application/json;
        add_header Access-Control-Allow-Origin "*";
        add_header Cache-Control "public, max-age=300";
    }

    location /statistics/map/logos/ {
        alias {{ ixp_portal_map_public_dir | default('/opt/sfmix/map-public') }}/logos/;
        add_header Access-Control-Allow-Origin "*";
        add_header Cache-Control "public, max-age=86400";
        add_header X-Content-Type-Options "nosniff";
    }

    location / {
        proxy_pass http://127.0.0.1:{{ ixp_portal_listen_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
{% endif %}
