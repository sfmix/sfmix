{% set cert_path = "/etc/letsencrypt/live/" + ixp_portal_domain %}
{% set has_cert = _portal_cert.stat.exists | default(false) %}

# HTTP — redirect to HTTPS (or serve ACME challenge if no cert yet)
server {
    listen 80;
    listen [::]:80;
    server_name {{ ixp_portal_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

{% if has_cert %}
    location / {
        return 301 https://{{ ixp_portal_domain }}$request_uri;
    }
{% endif %}
}

{% if has_cert %}
# HTTPS — reverse proxy to portal container
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ ixp_portal_domain }};

    ssl_certificate {{ cert_path }}/fullchain.pem;
    ssl_certificate_key {{ cert_path }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # The network map is built + served by the portal itself now (mapbuild app):
    # public map.json at /statistics/map/map.json (CORS-open) and the traffic feed
    # at /statistics/map/traffic, both proxied to Django below. map-links.json
    # stays private on the db volume and is never exposed.

    location / {
        proxy_pass http://127.0.0.1:{{ ixp_portal_listen_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
{% endif %}
