{% set cert_path = "/etc/letsencrypt/live/" + ixp_portal_domain %}
{% set has_cert = _portal_cert.stat.exists | default(false) %}

# HTTP — redirect to HTTPS (or serve ACME challenge if no cert yet)
server {
    listen 80;
    listen [::]:80;
    server_name {{ ixp_portal_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

{% if has_cert %}
    location / {
        return 301 https://{{ ixp_portal_domain }}$request_uri;
    }
{% endif %}
}

{% if has_cert %}
# HTTPS — reverse proxy to portal container
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name {{ ixp_portal_domain }};

    ssl_certificate {{ cert_path }}/fullchain.pem;
    ssl_certificate_key {{ cert_path }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Public network-map structure (map.json), rsynced from the metrics builder
    # into the private map dir. Only this exact file is routed; the sibling
    # map-links.json (opaque-id -> ports) has NO location and is never exposed.
    # CORS-open because the map page on sfmix.org fetches it cross-origin.
    location = /map/map.json {
        alias /var/lib/sfmix-map/map.json;
        default_type application/json;
        add_header Access-Control-Allow-Origin "*" always;
        add_header Cache-Control "public, max-age=300" always;
    }

    location / {
        proxy_pass http://127.0.0.1:{{ ixp_portal_listen_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
{% endif %}
