DJANGO_SECRET_KEY={{ ixp_portal_django_secret_key }}
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS={{ ixp_portal_domain }},localhost
OIDC_RP_CLIENT_ID={{ ixp_portal_oidc_client_id }}
OIDC_RP_CLIENT_SECRET={{ ixp_portal_oidc_client_secret }}
OIDC_PROVIDER_URL={{ ixp_portal_oidc_provider_url }}
IXP_LOOKING_GLASS_URL={{ ixp_portal_looking_glass_url }}
PROMETHEUS_URL={{ ixp_portal_prometheus_url }}
PROMETHEUS_TRUSTED_NETWORKS={{ ixp_portal_prometheus_trusted_networks }}
# NetBox — source of truth for the in-portal network-map builder (mapbuild + Q2)
NETBOX_API_ENDPOINT={{ ixp_netbox_api_endpoint }}
NETBOX_API_TOKEN={{ ixp_portal_netbox_token }}
# Host paths bind-mounted for nginx-direct asset serving (docker-compose.yml
# substitutes these; nginx serves the same paths via alias).
SFMIX_PORTAL_STATIC_DIR={{ ixp_portal_static_dir }}
SFMIX_MAP_PUBLIC_DIR={{ ixp_portal_map_public_dir }}
