# Akvorado configuration file
# Generated by Ansible - DO NOT EDIT MANUALLY

kafka:
  topic: {{ akvorado_kafka_topic }}
  brokers:
    - kafka:9092
  topic-configuration:
    num-partitions: {{ akvorado_kafka_partitions }}
    replication-factor: 1
    config-entries:
      segment.bytes: 1073741824
      retention.ms: 86400000
      cleanup.policy: delete
      compression.type: producer

clickhousedb:
  servers:
    - clickhouse:9000

geoip:
  optional: true
{% if akvorado_geoip_asn_database != "" %}
  asn-database:
    - /usr/share/GeoIP/asn.mmdb
{% endif %}
{% if akvorado_geoip_country_database != "" %}
  geo-database:
    - /usr/share/GeoIP/country.mmdb
{% endif %}

clickhouse:
  orchestrator-url: http://akvorado-orchestrator:8080
{% if akvorado_asns | length > 0 %}
  asns:
{% for asn, name in akvorado_asns.items() %}
    {{ asn }}: {{ name }}
{% endfor %}
{% endif %}
{% if akvorado_networks | length > 0 %}
  networks:
{% for prefix, attrs in akvorado_networks.items() %}
    {{ prefix }}:
{% for key, value in attrs.items() %}
      {{ key }}: {{ value }}
{% endfor %}
{% endfor %}
{% endif %}

inlet:
  flow:
    inputs:
      - type: udp
        decoder: netflow
        listen: :2055
        workers: {{ akvorado_flow_workers }}

outlet:
  metadata:
    providers:
      - type: snmp
        credentials:
          "::/0":
            communities:
{% for entry in akvorado_snmp_communities %}
              - {{ entry.community }}
{% endfor %}
{% if akvorado_exporter_classifiers | length > 0 %}
  core:
    exporter-classifiers:
{% for classifier in akvorado_exporter_classifiers %}
      - {{ classifier | to_json }}
{% endfor %}
{% if akvorado_interface_classifiers | length > 0 %}
    interface-classifiers:
{% for classifier in akvorado_interface_classifiers %}
      - {{ classifier | to_json }}
{% endfor %}
{% endif %}
{% endif %}

console:
  http:
    cache:
      type: redis
      server: redis:6379
