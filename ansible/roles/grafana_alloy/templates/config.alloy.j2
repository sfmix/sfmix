// Managed by Ansible (roles/grafana_alloy).
// Ships the systemd journal to Loki on {{ loki_push_host }}.

loki.source.journal "system" {
  max_age       = "{{ grafana_alloy_journal_max_age }}"
  path          = "{{ grafana_alloy_journal_path }}"
  forward_to    = [loki.write.default.receiver]
  relabel_rules = loki.relabel.journal.rules
  labels        = {
    job  = "journal",
    host = "{{ inventory_hostname }}",
  }
}

// Tail unattended-upgrades' own logs. apt's automatic upgrades write the
// package-level detail (what was upgraded, dpkg actions, shutdown installs)
// to these files, NOT to journald -- so this is the only way to see what
// actually changed, as opposed to merely that a run happened.
local.file_match "unattended_upgrades" {
  path_targets = [{
    __path__ = "{{ grafana_alloy_unattended_upgrades_glob }}",
    job      = "unattended-upgrades",
    host     = "{{ inventory_hostname }}",
  }]
}

loki.source.file "unattended_upgrades" {
  targets    = local.file_match.unattended_upgrades.targets
  forward_to = [loki.process.unattended_upgrades.receiver]
}

// Use the timestamp embedded in each line (e.g. "2026-06-20 06:22:11,453 INFO ...")
// as the log entry time. Without this, loki.source.file stamps lines at read
// time, so a full file read backfills every historical line at "now".
// Lines without a leading timestamp (dpkg continuation output) fall through
// and keep read time, which is fine.
loki.process "unattended_upgrades" {
  forward_to = [loki.write.default.receiver]

  stage.regex {
    expression = "^(?P<ts>\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\d{3})"
  }
  // unattended-upgrades logs in the host's local time. Alloy runs on the same
  // host, so "Local" resolves to that host's zone -- correct whether the host
  // is UTC or anything else, with no per-host config.
  stage.timestamp {
    source   = "ts"
    format   = "2006-01-02 15:04:05,000"
    location = "Local"
  }
}

// Keep labels bounded (low cardinality). Never label by message/PID.
loki.relabel "journal" {
  forward_to = []

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "severity"
  }
}

loki.write "default" {
  endpoint {
    url = "http://{{ loki_push_host }}:{{ loki_push_port }}/loki/api/v1/push"
  }

  // Buffer to disk so logs survive Loki/network blips and agent restarts.
  wal {
    enabled         = true
    max_segment_age = "1h"
  }
}
