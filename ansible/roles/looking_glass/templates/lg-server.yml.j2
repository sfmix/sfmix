{{ ansible_managed | comment }}

service:
  name: "SFMIX Looking Glass"
  operator: "SFMIX"
  operator_url: "https://sfmix.org"
  peeringdb_ix_id: 60

site:
  name: "central"
  display_name: "SFMIX Central Looking Glass"

rpc:
  bind: "{{ looking_glass_rpc_bind }}"
  secret_env: "LG_RPC_SECRET"

{% if looking_glass_oidc_enabled %}
auth:
  oidc:
    issuer: "{{ looking_glass_oidc_issuer }}"
    client_id: "{{ looking_glass_oidc_client_id }}"
    device_auth_endpoint: "{{ looking_glass_oidc_device_auth_endpoint }}"
    token_endpoint: "{{ looking_glass_oidc_token_endpoint }}"
    jwks_uri: "{{ looking_glass_oidc_jwks_uri }}"
    group_prefix: "{{ looking_glass_oidc_group_prefix }}"
    admin_group: "{{ looking_glass_oidc_admin_group }}"
    cert_lifetime_secs: {{ looking_glass_oidc_cert_lifetime_secs }}
{% if looking_glass_oidc_allowed_audiences is defined %}
    allowed_audiences:
{% for aud in looking_glass_oidc_allowed_audiences %}
      - "{{ aud }}"
{% endfor %}
{% endif %}
{% if looking_glass_oidc_allowed_issuers is defined %}
    allowed_issuers:
{% for iss in looking_glass_oidc_allowed_issuers %}
      - "{{ iss }}"
{% endfor %}
{% endif %}
{% endif %}

{# lg-server is the RPC backend only — it serves RPC on `rpc.bind` and does
   not run telnet/SSH frontends (lg-cli owns those, see lg-cli.yml.j2). An
   `ssh:` listener here is fatal (host_key is required and unsupported), and a
   `telnet:` listener would double-bind lg-cli's port. So no `listen:` block. #}
devices:
{% for device in looking_glass_devices %}
  - name: "{{ device.name }}"
    platform: {{ device.platform }}
    host: "{{ device.host | default(device.name) }}"
    port: {{ device.port | default(22) }}
    username: "{{ looking_glass_device_username }}"
    auth_method: {{ looking_glass_device_auth_method }}
{% if device.command_timeout_secs is defined %}
    command_timeout_secs: {{ device.command_timeout_secs }}
{% endif %}
{% endfor %}

participants:
  source: netbox
  url: "{{ looking_glass_netbox_url }}"
  token_env: "LG_NETBOX_TOKEN"
  refresh_interval_secs: {{ looking_glass_participants_refresh_interval | default(300) }}
{% if looking_glass_netbox_domain_suffix is defined %}
  domain_suffix: "{{ looking_glass_netbox_domain_suffix }}"
{% endif %}
  peeringdb:
    cache_file: "{{ looking_glass_peeringdb_cache_file | default('/var/lib/looking-glass/peeringdb-cache.json') }}"
    ttl_secs: {{ looking_glass_peeringdb_ttl_secs | default(86400) }}

vlans:
  public:
{% for vlan in looking_glass_public_vlans | default(["998", "999"]) %}
    - "{{ vlan }}"
{% endfor %}

device_cache:
  poll_interval_secs: {{ looking_glass_device_cache_poll_interval_secs | default(30) }}
  ttl:
    default: {{ looking_glass_device_cache_ttl_default | default(60) }}
    optics: {{ looking_glass_device_cache_ttl_optics | default(15) }}
    interfaces: {{ looking_glass_device_cache_ttl_interfaces | default(30) }}
    lldp_neighbors: {{ looking_glass_device_cache_ttl_lldp | default(120) }}
    mac_address_table: {{ looking_glass_device_cache_ttl_mac | default(30) }}
  # MAC-table store: first/last-seen tracking + last-known entries persisted
  # across restarts (lives under the ReadWritePaths state dir).
  mac_table_state_file: "{{ looking_glass_mac_table_state_file | default('/var/lib/looking-glass/mac-table.json') }}"
  mac_table_retention_secs: {{ looking_glass_mac_table_retention_secs | default(604800) }}

{% if looking_glass_discovered_sensor_url is defined %}
# Discovered ARP/NDP neighbors: poll the lg-neighborhood-watch sensor on the
# route server and accumulate a durable, persisted table (first/last-seen,
# conflict detection, tenant-change invalidation). State file lives under the
# ReadWritePaths state dir so history survives restarts.
discovered:
  sensor_url: "{{ looking_glass_discovered_sensor_url }}"
  poll_interval_secs: {{ looking_glass_discovered_poll_interval_secs | default(60) }}
  state_file: "{{ looking_glass_discovered_state_file | default('/var/lib/looking-glass/discovered-neighbors.json') }}"
{% endif %}

rate_limits:
  global:
    max_concurrent: 10
    commands_per_minute: 60
  per_device:
    max_concurrent: 2
    commands_per_minute: 20
  per_user:
    commands_per_minute: 10
