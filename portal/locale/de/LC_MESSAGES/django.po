msgstr ""

#: dashboard/views.py:538
#, python-format
msgid "%(port)s is down"
msgstr "%(port)s ist ausgefallen"

#: dashboard/views.py:539
msgid ""
"All member links are offline. Route-server sessions are idle and no traffic "
"is passing on this logical port."
msgstr ""
"Alle Mitgliedsverbindungen sind offline. Die Route-Server-Sitzungen sind "
"inaktiv und über diesen logischen Port fließt kein Verkehr."

#: dashboard/views.py:546
#, python-format
msgid "%(port)s degraded — %(up)s/%(total)s members up"
msgstr "%(port)s beeinträchtigt — %(up)s/%(total)s Mitglieder aktiv"

#: dashboard/views.py:552
#, python-format
msgid ""
"A member link is down; the bundle is running at %(effective)sG of "
"%(total)sG. Redundancy is lost until the link is restored."
msgstr ""
"Eine Mitgliedsverbindung ist ausgefallen; das Bündel läuft mit "
"%(effective)sG von %(total)sG. Die Redundanz ist verloren, bis die "
"Verbindung wiederhergestellt ist."

#: dashboard/views.py:571
#, python-format
msgid "%(port)s optic %(band)s on %(lane)s"
msgstr "Optik von %(port)s %(band)s auf %(lane)s"

#: dashboard/views.py:576
#, python-format
msgid ""
"RX %(rx)s dBm is outside the nominal window. Inspect the fiber / patch or "
"schedule an optic replacement."
msgstr ""
"RX %(rx)s dBm liegt außerhalb des Nominalbereichs. Überprüfen Sie die "
"Faser / das Patchkabel oder planen Sie einen Optik-Austausch."

#: dashboard/views.py:591
#, python-format
msgid "%(count)s route rejected on %(port)s"
msgid_plural "%(count)s routes rejected on %(port)s"
msgstr[0] "%(count)s Route auf %(port)s abgelehnt"
msgstr[1] "%(count)s Routen auf %(port)s abgelehnt"

#: dashboard/views.py:595
msgid ""
"Prefixes are being filtered (IRR / RPKI-invalid, bogon, or max-prefix). "
"Advertised routes may not be reaching peers as expected."
msgstr ""
"Präfixe werden gefiltert (IRR / RPKI-ungültig, Bogon oder Max-Prefix). "
"Angekündigte Routen erreichen die Peers möglicherweise nicht wie erwartet."

