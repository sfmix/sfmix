#: dashboard/views.py:527
#, python-format
msgid ""
"A MAC learned on this port is sourcing an address that is not assigned on "
"the IX (%(pairs)s). Using an unallocated peering-LAN IP is disallowed and "
"can disrupt other participants — correct the interface configuration."
msgstr ""

#: dashboard/views.py:538
#, python-format
msgid "%(port)s is down"
msgstr "%(port)s está caído"

#: dashboard/views.py:539
msgid ""
"All member links are offline. Route-server sessions are idle and no traffic "
"is passing on this logical port."
msgstr ""
"Todos los enlaces miembro están desconectados. Las sesiones del servidor de "
"rutas están inactivas y no pasa tráfico por este puerto lógico."

#: dashboard/views.py:546
#, python-format
msgid "%(port)s degraded — %(up)s/%(total)s members up"
msgstr "%(port)s degradado — %(up)s/%(total)s miembros activos"

#: dashboard/views.py:552
#, python-format
msgid ""
"A member link is down; the bundle is running at %(effective)sG of "
"%(total)sG. Redundancy is lost until the link is restored."
msgstr ""
"Un enlace miembro está caído; el grupo funciona a %(effective)sG de "
"%(total)sG. Se pierde la redundancia hasta que se restablezca el enlace."

#: dashboard/views.py:571
#, python-format
msgid "%(port)s optic %(band)s on %(lane)s"
msgstr "Óptica de %(port)s %(band)s en %(lane)s"

#: dashboard/views.py:576
#, python-format
msgid ""
"RX %(rx)s dBm is outside the nominal window. Inspect the fiber / patch or "
"schedule an optic replacement."
msgstr ""
"RX %(rx)s dBm está fuera del rango nominal. Inspeccione la fibra / el "
"latiguillo o programe el reemplazo de la óptica."

#: dashboard/views.py:591
#, python-format
msgid "%(count)s route rejected on %(port)s"
msgid_plural "%(count)s routes rejected on %(port)s"
msgstr[0] "%(count)s ruta rechazada en %(port)s"
msgstr[1] "%(count)s rutas rechazadas en %(port)s"
msgstr[2] "%(count)s rutas rechazadas en %(port)s"

#: dashboard/views.py:595
msgid ""
"Prefixes are being filtered (IRR / RPKI-invalid, bogon, or max-prefix). "
"Advertised routes may not be reaching peers as expected."
msgstr ""
"Se están filtrando prefijos (IRR / RPKI inválido, bogon o max-prefix). Es "
"posible que las rutas anunciadas no lleguen a los peers como se espera."

