#!/usr/bin/env python3
# Copyright (c) 2026 SFMIX. BSD-2-Clause license.
#
# LldpDomAgent — EOS SDK agent that reads optical RX power (DOM) from
# configured interfaces and advertises the values as custom LLDP
# organizationally-defined TLVs so the remote device can see how well
# its transmit light is being received.
#
# TLV encoding (two LLDP-MED TLVs per interface, OUI 00:12:BB / TIA):
#   Subtype 1  (Capabilities) — advertises Inventory bit so receivers parse Asset ID
#   Subtype 11 (Asset ID) — "dBm:-2.05" (single) or "dBm:-0.01/-0.87/-0.73/0.28" (multi-lane)
#
# SPECIAL VARIANT: Inventory subtypes 5-10 REMOVED.
# Deployed on switch01.sfo02 as a conservative reduction (Capabilities +
# Asset ID only). NOTE: the crash loop on switch01 was ultimately a null
# RX-power TypeError in format_rx_power (see below / README), NOT corrupted
# SDK state — the earlier "subtypes 5-10 trigger SIGABRT / needs reboot"
# theory was never confirmed. With the null-RX fix this variant runs stably;
# the full variant likely would too, but is left unverified on that box.
#
# IMPORTANT: TIA-1057 limits LLDP-MED Asset ID to 32 characters.
# Exceeding 32 chars causes EOS receivers to discard the entire LLDP PDU
# as an Rx Error, breaking neighbor discovery.  The "dBm:" prefix (4 chars)
# leaves 28 chars for values.  Worst-case 4-lane: "dBm:" + 4×"-10.00" + 3×"/" = 31 chars.
# 8-lane optics would exceed 32 chars at 2-decimal precision; if needed,
# reduce to 1 decimal or aggregate.
#
# EOS daemon config example:
#   daemon LldpDomAgent
#      exec /mnt/flash/LldpDomAgent
#      option POLL_INTERVAL value 30
#      no shutdown
#
# The agent discovers all LLDP-enabled Ethernet interfaces automatically
# and advertises RX power for every interface that has a transceiver with
# DOM data.

import eossdk
import json
import struct
import subprocess
import sys
import syslog

DEFAULT_POLL_SECS = 30    # Match LLDP tx-interval default

# TIA LLDP-MED constants
TIA_OUI = 0x0012BB
MED_SUBTYPE_CAPABILITIES = 1
MED_SUBTYPE_ASSET_ID = 11
# Capabilities payload: bits 0 (Capabilities) + 5 (Inventory), device type 4 (Network Connectivity)
MED_CAPS_PAYLOAD = struct.pack('>HB', 0x0021, 4).decode('latin-1')


def log(msg):
    syslog.syslog(syslog.LOG_INFO, "LldpDomAgent: %s" % msg)


def log_err(msg):
    syslog.syslog(syslog.LOG_ERR, "LldpDomAgent: %s" % msg)


def get_dom_data():
    """Fetch DOM data for all interfaces via EOS CLI JSON output.

    Uses 'show interfaces transceiver dom' which returns only interfaces
    that actually exist (excluding phantom breakout sub-ports) and provides
    per-channel RX power data for multi-lane optics.

    Prefers the in-process EOS eAPI unix-socket to avoid fork(), which can
    crash EOS SDK agents on certain platforms.  Falls back to subprocess
    (FastCli) if the socket isn't available.
    """
    # Method 1: local eAPI via Unix socket (no fork)
    try:
        import socket as _socket
        sock = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
        sock.settimeout(15)
        sock.connect("/var/run/command-api.sock")
        payload = json.dumps({
            "jsonrpc": "2.0", "method": "runCmds",
            "params": {"version": 1,
                       "cmds": ["show interfaces transceiver dom"],
                       "format": "json"},
            "id": 1
        })
        http_req = (
            "POST /command-api HTTP/1.0\r\n"
            "Content-Type: application/json\r\n"
            "Content-Length: %d\r\n\r\n%s" % (len(payload), payload))
        sock.sendall(http_req.encode())
        chunks = []
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            chunks.append(chunk)
        sock.close()
        raw = b"".join(chunks)
        body = raw.split(b"\r\n\r\n", 1)[1]
        resp = json.loads(body)
        return resp["result"][0].get("interfaces", {})
    except Exception as e:
        log("eAPI socket unavailable, trying FastCli: %s" % e)

    # Method 2: FastCli subprocess (works everywhere, but forks)
    try:
        result = subprocess.run(
            ["FastCli", "-p", "15", "-c",
             "show interfaces transceiver dom | json"],
            capture_output=True, text=True, timeout=15)
        if result.returncode == 0:
            data = json.loads(result.stdout)
            return data.get("interfaces", {})
    except Exception as e:
        log_err("FastCli failed: %s" % e)
    return {}


# LLDP-MED Asset ID maximum length (TIA-1057).  Exceeding this causes
# the receiving EOS switch to discard the entire LLDP PDU as an Rx Error.
MED_ASSET_ID_MAX_LEN = 32


def format_rx_power(intf_dom):
    """Build a self-describing RX power string for LLDP-MED Asset ID.

    Parses the 'show interfaces transceiver dom | json' structure where
    per-channel data lives under parameters.rxPower.channels.

    Uses the compact "dBm:" prefix (4 chars) to leave maximum room for
    values within the 32-char LLDP-MED Asset ID limit (TIA-1057).

    Returns a string like "dBm:-2.05" (single lane) or
    "dBm:-0.01/-0.87/-0.73/0.28" (multi-lane), or None.
    """
    params = intf_dom.get("parameters", {})
    rx_info = params.get("rxPower", {})
    channels = rx_info.get("channels", {})

    # Some transceivers report a present module with no RX reading: the channel
    # value comes back as null (None) or a non-numeric placeholder.  Drop those
    # so the comparisons below can't raise TypeError (e.g. None <= -30.0), which
    # would escape on_timeout and SIGABRT the agent via the SWIG director.
    channels = {k: v for k, v in channels.items()
                if isinstance(v, (int, float))}

    # Filter out the aggregate channel key "-"
    lane_keys = [k for k in channels if k != "-"]
    if len(lane_keys) > 1:
        powers = []
        all_dark = True
        for ch in sorted(lane_keys, key=int):
            val = channels[ch]
            if val > -30.0:
                all_dark = False
            powers.append("%.2f" % val)
        if all_dark:
            return None   # No light on any lane
        label = "dBm:%s" % "/".join(powers)
        if len(label) > MED_ASSET_ID_MAX_LEN:
            log_err("Asset ID too long (%d chars), skipping: %s" % (len(label), label))
            return None
        return label

    if lane_keys:
        val = channels[lane_keys[0]]
        if val <= -30.0:
            return None   # No light — port dark / unplugged
        return "dBm:%.2f" % val

    # Fallback: single-channel optics may only have the "-" key
    if "-" in channels:
        val = channels["-"]
        if val <= -30.0:
            return None
        return "dBm:%.2f" % val

    return None


class LldpDomAgent(eossdk.AgentHandler, eossdk.TimeoutHandler):
    def __init__(self, sdk):
        self.agent_mgr = sdk.get_agent_mgr()
        self.timeout_mgr = sdk.get_timeout_mgr()
        self.lldp_mgr = sdk.get_lldp_mgr()

        eossdk.AgentHandler.__init__(self, self.agent_mgr)
        eossdk.TimeoutHandler.__init__(self, self.timeout_mgr)

        self.poll_interval = DEFAULT_POLL_SECS
        # Track which interfaces have active TLVs so we can clean up
        self.active_intfs = set()

        # TLV type objects
        self.tlv_med_caps = None
        self.tlv_med_asset = None

        log("Agent constructed")

    def on_initialized(self):
        log("Initialized")
        self.tlv_med_caps = eossdk.LldpTlvType(TIA_OUI, MED_SUBTYPE_CAPABILITIES)
        self.tlv_med_asset = eossdk.LldpTlvType(TIA_OUI, MED_SUBTYPE_ASSET_ID)
        self._read_config()
        # Defer first poll to on_timeout so the event loop is fully started
        self.timeout_time_is(eossdk.now() + 5)

    def on_agent_option(self, key, value):
        """Called when a daemon option changes at runtime."""
        if key == "POLL_INTERVAL":
            try:
                self.poll_interval = int(value) if value else DEFAULT_POLL_SECS
                log("Poll interval set to %d seconds" % self.poll_interval)
            except ValueError:
                log_err("Invalid POLL_INTERVAL: %s" % value)

    def on_agent_enabled(self, enabled):
        if not enabled:
            log("Agent disabled, clearing TLVs")
            self._clear_all_tlvs()
            self.agent_mgr.agent_shutdown_complete_is(True)

    def on_timeout(self):
        self._poll_and_update()

    def _read_config(self):
        interval = self.agent_mgr.agent_option("POLL_INTERVAL")
        if interval:
            try:
                self.poll_interval = int(interval)
            except ValueError:
                pass
        log("Poll interval: %d seconds" % self.poll_interval)

    def _get_lldp_enabled_intfs(self):
        """Return the set of interface names with LLDP TX enabled."""
        enabled = set()
        for intf_id in self.lldp_mgr.lldp_intf_iter():
            if self.lldp_mgr.intf_enabled(intf_id):
                enabled.add(intf_id.to_string())
        return enabled

    def _poll_and_update(self):
        """Fetch DOM data and update LLDP TLVs for LLDP-enabled interfaces."""
        dom_data = get_dom_data()
        lldp_intfs = self._get_lldp_enabled_intfs()
        updated = set()

        for intf_name, intf_dom in dom_data.items():
            if intf_name not in lldp_intfs:
                continue
            # All per-interface work is wrapped so a single bad interface (e.g.
            # malformed DOM data) is logged and skipped instead of escaping
            # on_timeout and crashing the whole agent via the SWIG director.
            try:
                label = format_rx_power(intf_dom)
                if label is None:
                    continue
                intf_id = eossdk.IntfId(intf_name)
                neighbor = eossdk.LldpNeighbor(intf_id)
                self.lldp_mgr.tx_tlv_set(neighbor, self.tlv_med_caps, MED_CAPS_PAYLOAD)
                self.lldp_mgr.tx_tlv_set(neighbor, self.tlv_med_asset, label)
                updated.add(intf_name)
            except Exception as e:
                log_err("processing %s failed: %s" % (intf_name, e))

        # Clean up TLVs for interfaces that no longer have DOM data
        stale = self.active_intfs - updated
        for intf_name in stale:
            try:
                intf_id = eossdk.IntfId(intf_name)
                neighbor = eossdk.LldpNeighbor(intf_id)
                self.lldp_mgr.tx_tlv_del(neighbor, self.tlv_med_caps)
                self.lldp_mgr.tx_tlv_del(neighbor, self.tlv_med_asset)
            except Exception:
                pass

        added = updated - self.active_intfs
        removed = stale
        self.active_intfs = updated
        if added:
            log("Added TLVs on: %s" % ", ".join(sorted(added)))
        if removed:
            log("Removed TLVs from: %s" % ", ".join(sorted(removed)))

        # Schedule next poll (timeout_time_is is on TimeoutHandler, not TimeoutMgr)
        self.timeout_time_is(eossdk.now() + self.poll_interval)

    def _clear_all_tlvs(self):
        for intf_name in self.active_intfs:
            try:
                intf_id = eossdk.IntfId(intf_name)
                neighbor = eossdk.LldpNeighbor(intf_id)
                self.lldp_mgr.tx_tlv_del(neighbor, self.tlv_med_caps)
                self.lldp_mgr.tx_tlv_del(neighbor, self.tlv_med_asset)
            except Exception:
                pass
        self.active_intfs = set()


def main():
    syslog.openlog("LldpDomAgent", syslog.LOG_PID, syslog.LOG_LOCAL4)
    sdk = eossdk.Sdk("LldpDomAgent")
    _ = LldpDomAgent(sdk)  # Must stay alive for main_loop
    sdk.main_loop(sys.argv)


if __name__ == "__main__":
    main()
